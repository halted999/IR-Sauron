# Copy this file to .env and adjust values for your environment

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ir_timeline
REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ir-artifacts
MINIO_SECURE=false

# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_EXPIRE_DAYS=7

CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

DEBUG=false
