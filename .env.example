# =============================================================================
# IR Timeline Constructor — environment variables
# Скопируйте файл в .env и замените все значения перед запуском
# =============================================================================

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=irt_user
POSTGRES_PASSWORD=CHANGE_ME_postgres_strong_password
POSTGRES_DB=ir_timeline

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

# ── MinIO (S3-совместимое хранилище артефактов) ──────────────────────────────
MINIO_ACCESS_KEY=irt_minio_admin
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_min_8_chars
MINIO_BUCKET=artifacts
# Включить WORM-режим для критических доказательств (requires MinIO Enterprise или специальный режим)
ARTIFACT_WORM_ENABLED=false

# ── Backend ──────────────────────────────────────────────────────────────────
# Генерация: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_random_64_char_hex_string_here_00000000000000
JWT_EXPIRE_MINUTES=60
# Разрешённые источники запросов (через запятую)
CORS_ORIGINS=https://irt.example.com
# Сбросить пароль admin → "admin" при следующем старте backend (поставьте false после первого запуска)
RESET_ADMIN_PASSWORD=true

# ── Keycloak SSO (только с --profile sso) ────────────────────────────────────
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password
KEYCLOAK_HOSTNAME=irt.example.com

# OIDC-параметры для backend (заполнить после настройки Keycloak realm)
OIDC_ISSUER_URL=https://irt.example.com/auth/realms/irt
OIDC_CLIENT_ID=irt-backend
OIDC_CLIENT_SECRET=CHANGE_ME_oidc_client_secret

# ── Dev-only ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@irt.local
PGADMIN_PASSWORD=admin
